# BiasClear API Configuration
# Copy to .env and fill in your values

# LLM Provider: "bedrock" (default) or "gemini"
BIASCLEAR_LLM_PROVIDER=bedrock

# Bedrock Provider (production default)
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
#
# Auth option 1 (recommended for Render): Bedrock API key
# AWS_BEARER_TOKEN_BEDROCK=your-bedrock-api-key-here
#
# Auth option 2: Standard AWS credentials (for local dev or IAM-based deploys)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# Or use ~/.aws/credentials / IAM role (auto-detected by boto3)

# Gemini Provider (fallback — set BIASCLEAR_LLM_PROVIDER=gemini to use)
# GEMINI_API_KEY=your-api-key-here
# GEMINI_MODEL=gemini-2.5-flash

# Audit database path
BIASCLEAR_AUDIT_DB=biasclear_audit.db

# Learning ring — confirmations before auto-activation
BIASCLEAR_PATTERN_THRESHOLD=5

# Learning ring — false positive rate limit (0.15 = 15%)
BIASCLEAR_FP_LIMIT=0.15

# Playground — HMAC secret for session tokens (auto-generated if not set)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# BIASCLEAR_PLAYGROUND_SECRET=

# Playground rate limits (per-IP, unauthenticated traffic)
BIASCLEAR_PLAYGROUND_RATE_PER_MINUTE=10
BIASCLEAR_PLAYGROUND_RATE_PER_HOUR=100

# Auth — comma-separated API keys (leave empty to disable auth in dev)
# Generate keys with: python -c "from biasclear.auth import generate_api_key; print(generate_api_key())"
BIASCLEAR_API_KEYS=

# Rate limiting
BIASCLEAR_RATE_LIMIT=true
BIASCLEAR_RATE_PER_MINUTE=60
BIASCLEAR_RATE_PER_HOUR=1000

# CORS — comma-separated allowed origins
# Production default: https://biasclear.com (set in config.py)
# Use * for local development only
BIASCLEAR_CORS_ORIGINS=*

# Logging
BIASCLEAR_LOG_LEVEL=INFO
BIASCLEAR_LOG_FORMAT=json

# OpenAPI docs — set to "true" to expose /docs in production
# BIASCLEAR_DOCS_ENABLED=false

# Server
BIASCLEAR_HOST=0.0.0.0
BIASCLEAR_PORT=8000
